FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/sync-engine ./cmd/sync-engine

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /bin/sync-engine /usr/local/bin/sync-engine

EXPOSE 8081
ENTRYPOINT ["sync-engine"]
