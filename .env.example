# SQL Server (Legacy - read only)
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=IBS
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStr0ngP@ssword

# PostgreSQL (New metadata store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=ibs_doc_engine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable

# MinIO (Object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ibs-documents
MINIO_USE_SSL=false

# Sync Engine
SYNC_POLL_INTERVAL=30s
SYNC_BATCH_SIZE=100
SYNC_WORKERS=10

# Logging
LOG_LEVEL=info
